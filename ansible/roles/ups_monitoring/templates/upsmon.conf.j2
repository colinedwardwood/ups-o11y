{% for ups in nut_ups_devices %}
MONITOR {{ ups.name }}@localhost:{{ nut_listen_port }} {{ ups.powervalue | default(1) }} {{ nut_user }} {{ nut_password }} primary
{% endfor %}
MINSUPPLIES 1
SHUTDOWNCMD "/sbin/shutdown -h +0"
POLLFREQ 5
POLLFREQALERT 5
HOSTSYNC 15
DEADTIME 15
POWERDOWNFLAG /etc/killpower
RBWARNTIME 43200
NOCOMMWARNTIME 300
FINALDELAY 5
